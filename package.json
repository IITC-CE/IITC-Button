{
  "name": "iitc-button",
  "version": "3.2.5",
  "repository": "https://github.com/IITC-CE/IITC-Button.git",
  "license": "GPLv3",
  "private": true,
  "scripts": {
    "dev:firefox": "wxt -b firefox",
    "dev:chrome": "wxt -b chrome",
    "build_mv3_firefox": "wxt build -b firefox --mv3 && wxt zip -b firefox --mv3",
    "build_mv3_chrome": "wxt build -b chrome --mv3 && wxt zip -b chrome --mv3",
    "build_mv3_safari": "wxt build -b safari --mv3 && wxt zip -b safari --mv3",
    "zip_sources": "wxt zip -b firefox --mv3 --sources",
    "postinstall": "wxt prepare",
    "lint": "eslint .",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@highlightjs/vue-plugin": "^2.1.0",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "lib-iitc-manager": "^2.0.1",
    "mitt": "^3.0.1",
    "scored-fuzzysearch": "^1.0.5",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@wxt-dev/module-vue": "^1.0.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^16.0.0",
    "prettier": "^3.0.0",
    "publish-browser-extension": "^2.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "webextension-polyfill": "^0.10.0",
    "wxt": "^0.20.26"
  },
  "readme": "README.md"
}
